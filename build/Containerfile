FROM golang:1.23.4 AS build
WORKDIR /build

RUN useradd -u 10001 app-user

COPY go.mod go.sum .
RUN go mod download

COPY cmd/dummy_ai/main.go cmd/dummy_ai/
COPY pkg/env/env.go pkg/env/
COPY web/server/server.go web/server/
RUN CGO_ENABLED=0 go build -o app ./cmd/dummy_ai/

FROM scratch AS app
WORKDIR /app

ARG HOST=localhost
ARG PORT=8080

COPY --from=build /etc/passwd /etc/passwd
COPY --from=build build/app .
COPY web/server/server.html web/server/
COPY web/static/ web/static/

USER app-user
EXPOSE $PORT

ENTRYPOINT ["./app"]
CMD ["SERVER_ADDRESS=$HOST:$PORT"]
