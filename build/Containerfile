FROM golang:1.23.4 AS build

WORKDIR /build

COPY go.mod \
     go.sum \
     .

RUN go mod download

COPY cmd/dummy_ai/main.go \
     pkg/env/env.go       \
     web/server/server.go \
     .

RUN CGO_ENABLED=0 go build ./cmd/dummy_ai

FROM scratch

COPY . .

COPY --from=build     \
     ./build/dummy_ai \
     .

USER 1001

EXPOSE 3000

ENTRYPOINT ["/dummy_ai"]
